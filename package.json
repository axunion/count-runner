{
  "name": "vite-solid-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "check": "biome check . && tsc -b",
    "fix": "biome check --write ."
  },
  "dependencies": {
    "@kobalte/core": "^0.13.12",
    "lucide-solid": "^1.23.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^24.13.2",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
